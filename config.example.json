{
  "hotkey": "<cmd>+<shift>+d",
  "recording": {
    "sample_rate": 16000,
    "channels": 1,
    "device": null
  },
  "whisper": {
    "model": "tiny.en",
    "device": "auto",
    "compute_type": "int8",
    "language": "en"
  },
  "rewriter": {
    "provider": "none",
    "model": "llama3.2:1b",
    "ollama_url": "http://127.0.0.1:11434/api/generate",
    "timeout_seconds": 90,
    "style": "polished, concise, and well structured",
    "preserve_intent": true
  },
  "paste": {
    "enabled": true,
    "restore_clipboard": false,
    "paste_delay_seconds": 0.1
  }
}
